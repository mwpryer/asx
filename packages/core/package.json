{
  "name": "@mwp13/asx-core",
  "version": "0.0.1",
  "private": true,
  "description": "Asana client, auth, errors, output, and types for asx",
  "license": "MIT",
  "author": "mwpryer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwpryer/asx.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "tsup",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@stricli/core": "^1.2.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "5.9.2",
    "vitest": "^3.2.1"
  }
}
